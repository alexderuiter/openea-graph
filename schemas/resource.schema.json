{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openea.example/schema/resource.schema.json",
  "title": "OpenEA Graph Resource",
  "type": "object",
  "required": ["uri", "type", "name", "lifecycle"],
  "properties": {
    "uri": { "type": "string", "format": "uri" },
    "type": { "type": "string", "format": "uri" },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "lifecycle": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": {
          "enum": ["concept", "planned", "inUse", "phasingOut", "retired", "rejected"]
        },
        "validFrom": { "type": "string", "format": "date" },
        "expectedUntil": { "type": "string", "format": "date" }
      },
      "additionalProperties": false
    },
    "properties": { "type": "object", "additionalProperties": true },
    "provenance": { "$ref": "provenance.schema.json" }
  },
  "additionalProperties": false
}
