{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openea.example/schema/resource.schema.json",
  "title": "OpenEA Graph Resource",
  "type": "object",
  "required": ["uri", "type", "name"],
  "properties": {
    "uri": {
      "type": "string",
      "format": "uri",
      "description": "An absolute URI or a compact identifier using a namespace prefix declared by the repository."
    },
    "type": {
      "type": "string",
      "format": "uri",
      "description": "An absolute type URI or a compact identifier using a declared namespace prefix."
    },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "status": {
      "enum": ["concept", "planned", "inUse", "phasingOut", "retired", "rejected"]
    },
    "confidence": {
      "enum": ["proposed", "assumed", "uncertain", "verified"]
    },
    "properties": { "type": "object", "additionalProperties": true },
    "provenance": { "$ref": "provenance.schema.json" }
  },
  "additionalProperties": false
}
